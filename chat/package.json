{
    "name": "chatbot-mcp-availability",
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "node --loader tsx ./src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "build:frontend": "tsc --project tsconfig.frontend.json",
        "docker:build": "docker build -t chatbot-mcp .",
        "docker:run": "docker run -p 3000:3000 --env-file .env chatbot-mcp"
    },
    "dependencies": {
        "@google/genai": "^1.25.0",
        "@modelcontextprotocol/sdk": "^1.19.1",
        "axios": "^1.6.0",
        "better-sqlite3": "^11.10.0",
        "cors": "^2.8.5",
        "dompurify": "^3.2.7",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "marked": "^16.4.0",
        "openai": "^4.20.1",
        "ws": "^8.14.2"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/node": "^20.10.5",
        "@types/ws": "^8.5.10",
        "tsx": "^4.6.2",
        "typescript": "^5.3.3"
    }
}